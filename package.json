{
  "name": "gerenciador-de-tarefas",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "test:dev": "set NODE_OPTIONS=--experimental-vm-modules && npx jest --watchAll --runInBand",
    "build": "prisma generate && tsup src --format esm --out-dir build",
    "start": "node --env-file=.env build/server.js"
  },
  "author": "Roberto Kennedy",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@jest/types": "^30.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typerscript": "^0.2.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
